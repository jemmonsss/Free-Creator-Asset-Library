# .gitattributes

# Set default behavior to automatically normalize line endings
* text=auto

# Mark binary file types and disable diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.mp3 binary
*.wav binary
*.ogg binary
*.flac binary
*.fbx binary
*.obj binary
*.blend binary
*.dae binary
*.stl binary
*.zip binary
*.rar binary
*.7z binary

# Treat text files as text
*.md text
*.txt text
*.py text
*.sh text
*.js text
*.json text
*.yml text
*.yaml text

# Optional: Use Git LFS for large binary files (uncomment if using LFS)
# *.png filter=lfs diff=lfs merge=lfs -text
# *.fbx filter=lfs diff=lfs merge=lfs -text
